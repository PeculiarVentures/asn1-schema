{
  "name": "asn1-schema-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@peculiar/eslint-config-base": "^0.2.9",
    "@peculiar/utils": "^2.0.2",
    "@types/node": "^25.6.0",
    "@types/rimraf": "^3.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint-import-resolver-typescript": "^4.4.4",
    "lerna": "^9.0.7",
