{
  "name": "asn1-schema-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "eslint-import-resolver-typescript": "^4.4.4",
    "@peculiar/eslint-config-base": "^0.2.9",
    "@types/node": "^24.0.14",
    "@vitest/coverage-v8": "^4.1.5",
    "lerna": "^9.0.7",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "scripts": {
